#!/bin/bash
# ShellFrame launcher — runs source directly with full user environment
# Source user profile for PATH (nvm, .local/bin, etc.)
if [ -f "$HOME/.zprofile" ]; then source "$HOME/.zprofile"; fi
if [ -f "$HOME/.zshrc" ]; then source "$HOME/.zshrc" 2>/dev/null; fi

# Resolve real path through symlinks (~/Applications/ShellFrame.app is a symlink)
SELF="$0"
if [ -L "$SELF" ]; then
  SELF="$(readlink "$SELF")"
fi
DIR="$(cd "$(dirname "$SELF")/../../.." 2>/dev/null && pwd)"

# If DIR doesn't have .venv, try the hardcoded install path as fallback
if [ ! -d "$DIR/.venv" ] && [ ! -d "$DIR/libexec/.venv" ]; then
  DIR="$HOME/.local/apps/shellframe"
fi

# Support both regular and Homebrew installs
if [ -d "$DIR/libexec/.venv" ]; then
  cd "$DIR/libexec"
else
  cd "$DIR"
fi

exec .venv/bin/python main.py "$@"
